{
  "name": "openproxy-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
    "typecheck:all": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "build": "node build.mjs && tsc --emitDeclarationOnly",
    "build:watch": "node build.mjs --watch",
    "test:e2e": "echo 'e2e tests live in tests/e2e/ — handled in a later gate' && exit 0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.19.21",
    "esbuild": "^0.28.1",
    "typescript": "5.6.3"
  },
  "dependencies": {
    "lit-html": "^3.3.3"
  }
}
