{
  "name": "openproxy-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
    "typecheck:all": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "build": "node build.mjs && tsc --emitDeclarationOnly",
    "build:watch": "node build.mjs --watch",
    "test:e2e": "cp tests/e2e/data-test.seed.db tests/e2e/data-test.db && playwright test",
    "test": "vitest run src/static/src"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.19.21",
    "esbuild": "^0.28.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "lit-html": "^3.3.3",
    "uplot": "^1.6.31"
  }
}
